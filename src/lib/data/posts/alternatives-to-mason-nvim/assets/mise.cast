[52.875964, "o", "\u001b[0m\u001b[1m\u001b[38;2;117;113;249mTools\r\n\u001b[0m\u001b[38;5;243mSelect a tool to install\r\n \u001b[0m\u001b[38;5;252m aws-vault                 \u001b[0m\u001b[38;5;243m  A vault for securely storing and accessing AWS credentials in development environments\r\n \u001b[0m\u001b[38;5;252m awscli-local              \u001b[0m\u001b[38;5;243m  This package provides the awslocal command, which is a thin wrapper around the aws command line interface for use with LocalStack\r\n \u001b[0m\u001b[38;5;252m awsebcli                  \u001b[0m\u001b[38;5;243m  The AWS Elastic Beanstalk Command Line Interface (EB CLI) is a tool that helps you deploy and manage your Elastic Beanstalk applications and environments. It also provides integration with Git\r\n \u001b[0m\u001b[38;5;252m awsls                     \u001b[0m\u001b[38;5;243m  A list command for AWS resources\r\n \u001b[0m\u001b[38;5;252m awsrm                     \u001b[0m\u001b[38;5;243m  A remove command for AWS resources\r\n \u001b[0m\u001b[38;5;252m awsweeper                 \u001b[0m\u001b[38;5;243m  A tool for cleaning your AWS account\r\n \u001b[0m\u001b[38;5;252m azure                     \u001b[0m\u001b[38;5;243m  azure-cli (az)\r\n \u001b[0m\u001b[38;5;252m azure-functions-core-tools\u001b[0m\u001b[38;5;243m  Command line tools for Azure Functions\r\n \u001b[0m\u001b[38;5;252m azure-kubelogin           \u001b[0m\u001b[38;5;243m  A Kubernetes credential (exec) plugin implementing azure authentication\r\n \u001b[0m\u001b[38;5;252m babashka                  \u001b[0m\u001b[38;5;243m  Native, fast starting Clojure interpreter for scripting\r\n \u001b[0m\u001b[38;5;252m balena                    \u001b[0m\u001b[38;5;243m  The balena CLI is a Command Line Interface for balenaCloud or openBalena\r\n \u001b[0m\u001b[38;5;252m bashbot                   \u001b[0m\u001b[38;5;243m  A slack-bot written in golang for infrastructure/devops teams\r\n \u001b[0m\u001b[38;5;252m bashly                    \u001b[0m\u001b[38;5;243m  Bashly is a command line application (written in Ruby) that lets you generate feature-rich bash command line tools\r\n \u001b[0m\u001b[38;5;252m bat                       \u001b[0m\u001b[38;5;243m  A cat(1) clone with wings\r\n \u001b[0m\u001b[38;5;252m bat-extras                \u001b[0m\u001b[38;5;243m  Bash scripts that integrate bat with various command line tools\r\n \u001b[0m\u001b[38;5;252m bats                      \u001b[0m\u001b[38;5;243m  Bash Automated Testing System\r\n \u001b[0m\u001b[38;5;252m bazel                     \u001b[0m\u001b[38;5;243m  a fast, scalable, multi-language and extensible build system\r\n\u001b[0m\u001b[38;2;247;128;226m❯\u001b[0m\u001b[38;5;252m bazel-watcher             \u001b[0m\u001b[38;5;243m  Tools for building Bazel targets when source files change\r\n \u001b[0m\u001b[38;5;252m bazelisk                  \u001b[0m\u001b[38;5;243m  A user-friendly launcher for Bazel\r\n \u001b[0m\u001b[38;5;252m bosh-backup-and-restore   \u001b[0m\u001b[38;5;243m  BOSH Backup and Restore is a CLI utility for orchestrating the backup and restore of BOSH deployments and BOSH directors\r\n \u001b[0m\u001b[38;5;252m redpanda-connect          \u001b[0m\u001b[38;5;243m  Fancy stream processing made operationally mundane\r\n \u001b[0m\u001b[38;5;252m bfs                       \u001b[0m\u001b[38;5;243m  Breadth-first search for your files\r\n \u001b[0m\u001b[38;5;252m bibtex-tidy               \u001b[0m\u001b[38;5;243m  Cleaner and Formatter for BibTeX files\r\n \u001b[0m\u001b[38;5;252m binnacle                  \u001b[0m\u001b[38;5;243m  An opinionated tool to interact with Kubernetes' Helm\r\n \u001b[0m\u001b[38;5;252m biome                     \u001b[0m\u001b[38;5;243m  A toolchain for web projects, aimed to provide functionalities to maintain them. Biome offers formatter and linter, usable via CLI and LSP\r\n\u001b[0m\u001b[38;2;2;191;135m/\u001b[0m\u001b[0m\u001b[30m\u001b[47m \u001b[0m\r\n\u001b[0m\u001b[0m\u001b[38;2;98;98;98mesc\u001b[0m\u001b[38;2;74;74;74m clear filter\u001b[0m\u001b[38;2;60;60;60m • \u001b[0m\u001b[38;2;98;98;98menter\u001b[0m\u001b[38;2;74;74;74m confirm\r\n\u001b[0m\u001b[?25l"]
[52.915888, "o", "\u001b[29A\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K"]
