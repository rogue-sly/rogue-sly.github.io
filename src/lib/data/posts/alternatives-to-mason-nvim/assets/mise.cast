[55.930766, "o", "\u001b[0m\u001b[1m\u001b[38;2;117;113;249mTools\r\n\u001b[0m\u001b[38;5;243mSelect a tool to install\r\n \u001b[0m\u001b[38;5;252m cilium-hubble   \u001b[0m\u001b[38;5;243m  Hubble - Network, Service & Security Observability for Kubernetes using eBPF\r\n \u001b[0m\u001b[38;5;252m circleci        \u001b[0m\u001b[38;5;243m  Use CircleCI from the command line\r\n \u001b[0m\u001b[38;5;252m clang           \u001b[0m\u001b[38;5;243m  Clang is an 'LLVM native' C/C++/Objective-C compiler, which aims to deliver amazingly fast compiles, extremely useful error and warning messages and to provide a platform for building great source level tools\r\n \u001b[0m\u001b[38;5;252m clang-format    \u001b[0m\u001b[38;5;243m  format C/C++/Java/JavaScript/JSON/Objective-C/Protobuf/C# code\r\n \u001b[0m\u001b[38;5;252m clarinet        \u001b[0m\u001b[38;5;243m  Write, test and deploy high-quality smart contracts to the Stacks blockchain and Bitcoin\r\n \u001b[0m\u001b[38;5;252m claude          \u001b[0m\u001b[38;5;243m  Claude Code is an agentic coding tool that lives in your terminal, understands your codebase, and helps you code faster by executing routine tasks, explaining complex code, and handling git workflows -- all through natural language commands\r\n \u001b[0m\u001b[38;5;252m claude-powerline\u001b[0m\u001b[38;5;243m  Beautiful vim-style powerline statusline for Claude Code\r\n \u001b[0m\u001b[38;5;252m claude-squad    \u001b[0m\u001b[38;5;243m  Manage multiple AI agents like Claude Code, Aider, Codex, and Amp. 10x your productivity\r\n \u001b[0m\u001b[38;5;252m cli53           \u001b[0m\u001b[38;5;243m  Command line tool for Amazon Route 53\r\n \u001b[0m\u001b[38;5;252m clickhouse      \u001b[0m\u001b[38;5;243m  ClickHouse® is a high-performance, column-oriented SQL database management system (DBMS) for online analytical processing (OLAP)\r\n \u001b[0m\u001b[38;5;252m clj-kondo       \u001b[0m\u001b[38;5;243m  Static analyzer and linter for Clojure code that sparks joy\r\n \u001b[0m\u001b[38;5;252m cljstyle        \u001b[0m\u001b[38;5;243m  A tool for formatting Clojure code\r\n \u001b[0m\u001b[38;5;252m clojure         \u001b[0m\u001b[38;5;243m  The Clojure Programming Language\r\n \u001b[0m\u001b[38;5;252m cloud-sql-proxy \u001b[0m\u001b[38;5;243m  A utility for connecting securely to your Cloud SQL instances\r\n \u001b[0m\u001b[38;5;252m cloudflared     \u001b[0m\u001b[38;5;243m  cloudflared connects your machine or user identity to Cloudflare's global network\r\n \u001b[0m\u001b[38;5;252m clusterawsadm   \u001b[0m\u001b[38;5;243m  clusterawsadm provides helpers for bootstrapping Kubernetes Cluster API Provider AWS\r\n"]
[55.930774, "o", " \u001b[0m\u001b[38;5;252m clusterctl      \u001b[0m\u001b[38;5;243m  Home for Cluster API, a subproject of sig-cluster-lifecycle\r\n \u001b[0m\u001b[38;5;252m cmake           \u001b[0m\u001b[38;5;243m  CMake is a tool to manage building of source code. Originally, CMake was designed as a generator for various dialects of Makefile, today CMake generates modern buildsystems such as Ninja as well as project files for IDEs such as Visual Studio and Xcode\r\n\u001b[0m\u001b[38;2;247;128;226m❯\u001b[0m\u001b[38;5;252m cmctl           \u001b[0m\u001b[38;5;243m  the command line utility that makes cert-manager'ing easier\r\n \u001b[0m\u001b[38;5;252m cmdx            \u001b[0m\u001b[38;5;243m  Task runner. It provides useful help messages and supports interactive prompts and validation of arguments\r\n \u001b[0m\u001b[38;5;252m cockroach       \u001b[0m\u001b[38;5;243m  A distributed SQL database designed for speed, scale, and survival\r\n \u001b[0m\u001b[38;5;252m cocoapods       \u001b[0m\u001b[38;5;243m  CocoaPods is a dependency manager for Swift and Objective-C Cocoa projects\r\n \u001b[0m\u001b[38;5;252m cocogitto       \u001b[0m\u001b[38;5;243m  The Conventional Commits toolbox\r\n \u001b[0m\u001b[38;5;252m code            \u001b[0m\u001b[38;5;243m  Fast, effective, mind-blowing, coding CLI. Browser integration, multi-agents, theming, and reasoning control. Orchestrate agents from OpenAI, Claude, Gemini or any provider.\r\n \u001b[0m\u001b[38;5;252m codebuff        \u001b[0m\u001b[38;5;243m  Codebuff is a CLI tool that writes code for you\r\n\u001b[0m\u001b[38;2;2;191;135m/\u001b[0m\u001b[0m\u001b[30m\u001b[47m \u001b[0m\r\n"]
[55.930779, "o", "\u001b[0m\u001b[0m\u001b[38;2;98;98;98mesc\u001b[0m\u001b[38;2;74;74;74m clear filter\u001b[0m\u001b[38;2;60;60;60m • \u001b[0m\u001b[38;2;98;98;98menter\u001b[0m\u001b[38;2;74;74;74m confirm\r\n\u001b[0m\u001b[?25l"]
