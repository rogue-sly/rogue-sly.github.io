[54.203186, "o", "\u001b[0m\u001b[1m\u001b[38;2;117;113;249mTools\r\n\u001b[0m\u001b[38;5;243mSelect a tool to install\r\n\u001b[0m\u001b[38;2;247;128;226m❯\u001b[0m\u001b[38;5;252m cargo-binstall\u001b[0m\u001b[38;5;243m  Binary installation for rust projects\r\n \u001b[0m\u001b[38;5;252m cargo-insta   \u001b[0m\u001b[38;5;243m  A snapshot testing library for rust\r\n \u001b[0m\u001b[38;5;252m cargo-make    \u001b[0m\u001b[38;5;243m  Rust task runner and build tool\r\n \u001b[0m\u001b[38;5;252m carp          \u001b[0m\u001b[38;5;243m  Carp Language\r\n \u001b[0m\u001b[38;5;252m carthage      \u001b[0m\u001b[38;5;243m  A simple, decentralized dependency manager for Cocoa\r\n \u001b[0m\u001b[38;5;252m ccache        \u001b[0m\u001b[38;5;243m  ccache – a fast compiler cache\r\n \u001b[0m\u001b[38;5;252m certstrap     \u001b[0m\u001b[38;5;243m  Tools to bootstrap CAs, certificate requests, and signed certificates\r\n \u001b[0m\u001b[38;5;252m cf            \u001b[0m\u001b[38;5;243m  The official command line client for Cloud Foundry\r\n \u001b[0m\u001b[38;5;252m cfn-lint      \u001b[0m\u001b[38;5;243m  Checks CloudFormation templates for practices and behaviour that could potentially be improved\r\n \u001b[0m\u001b[38;5;252m cfssl         \u001b[0m\u001b[38;5;243m  CFSSL: Cloudflare's PKI and TLS toolkit\r\n \u001b[0m\u001b[38;5;252m cfssljson     \u001b[0m\u001b[38;5;243m  cfssljson: Takes the JSON output from Cloudflare's cfssl and multirootca programs and writes certificates, keys, CSRs, and bundles to disk.\r\n \u001b[0m\u001b[38;5;252m chamber       \u001b[0m\u001b[38;5;243m  CLI for managing secrets\r\n \u001b[0m\u001b[38;5;252m changie       \u001b[0m\u001b[38;5;243m  Automated changelog tool for preparing releases with lots of customization options\r\n \u001b[0m\u001b[38;5;252m cheat         \u001b[0m\u001b[38;5;243m  cheat allows you to create and view interactive cheatsheets on the command-line. It was designed to help remind *nix system administrators of options for commands that they use frequently, but not frequently enough to remember\r\n \u001b[0m\u001b[38;5;252m checkmake     \u001b[0m\u001b[38;5;243m  experimental linter/analyzer for Makefiles\r\n \u001b[0m\u001b[38;5;252m checkov       \u001b[0m\u001b[38;5;243m  Prevent cloud misconfigurations and find vulnerabilities during build-time in infrastructure as code, container images and open source packages with Checkov by Bridgecrew\r\n \u001b[0m\u001b[38;5;252m chezmoi       \u001b[0m\u001b[38;5;243m  Manage your dotfiles across multiple diverse machines, securely\r\n \u001b[0m\u001b[38;5;252m chezscheme    \u001b[0m\u001b[38;5;243m  Chez Scheme is both a programming language and an implementation of that language, with supporting tools and documentation\r\n \u001b[0m\u001b[38;5;252m chicken       \u001b[0m\u001b[38;5;243m  CHICKEN is a compiler for the Scheme programming language\r\n \u001b[0m\u001b[38;5;252m chisel        \u001b[0m\u001b[38;5;243m  A fast TCP/UDP tunnel over HTTP\r\n \u001b[0m\u001b[38;5;252m choose        \u001b[0m\u001b[38;5;243m  A human-friendly and fast alternative to cut (and sometimes awk)\r\n \u001b[0m\u001b[38;5;252m chromedriver  \u001b[0m\u001b[38;5;243m  ChromeDriver is a standalone server that implements the W3C WebDriver and WebDriver BiDi standards\r\n \u001b[0m\u001b[38;5;252m cidr-merger   \u001b[0m\u001b[38;5;243m  A simple command line tool to merge ip/ip cidr/ip range, supports IPv4/IPv6\r\n \u001b[0m\u001b[38;5;252m cidrchk       \u001b[0m\u001b[38;5;243m  CLI tool for CIDR range operations (check, generate)\r\n \u001b[0m\u001b[38;5;252m cilium-cli    \u001b[0m\u001b[38;5;243m  CLI to install, manage & troubleshoot Kubernetes clusters running Cilium\r\n\u001b[0m\u001b[38;2;2;191;135m/\u001b[0m\u001b[0m\u001b[30m\u001b[47m \u001b[0m\r\n\u001b[0m\u001b[0m\u001b[38;2;98;98;98mesc\u001b[0m\u001b[38;2;74;74;74m clear filter\u001b[0m\u001b[38;2;60;60;60m • \u001b[0m\u001b[38;2;98;98;98menter\u001b[0m\u001b[38;2;74;74;74m confirm\r\n\u001b[0m\u001b[?25l"]
[54.243027, "o", "\u001b[29A\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\r\u001b[2K\u001b[1B\u001b[29A"]
[54.24331, "o", "\u001b[0m\u001b[1m\u001b[38;2;117;113;249mTools\r\n\u001b[0m\u001b[38;5;243mSelect a tool to install\r\n \u001b[0m\u001b[38;5;252m cargo-binstall\u001b[0m\u001b[38;5;243m  Binary installation for rust projects\r\n\u001b[0m\u001b[38;2;247;128;226m❯\u001b[0m\u001b[38;5;252m cargo-insta   \u001b[0m\u001b[38;5;243m  A snapshot testing library for rust\r\n \u001b[0m\u001b[38;5;252m cargo-make    \u001b[0m\u001b[38;5;243m  Rust task runner and build tool\r\n \u001b[0m\u001b[38;5;252m carp          \u001b[0m\u001b[38;5;243m  Carp Language\r\n \u001b[0m\u001b[38;5;252m carthage      \u001b[0m\u001b[38;5;243m  A simple, decentralized dependency manager for Cocoa\r\n \u001b[0m\u001b[38;5;252m ccache        \u001b[0m\u001b[38;5;243m  ccache – a fast compiler cache\r\n \u001b[0m\u001b[38;5;252m certstrap     \u001b[0m\u001b[38;5;243m  Tools to bootstrap CAs, certificate requests, and signed certificates\r\n \u001b[0m\u001b[38;5;252m cf            \u001b[0m\u001b[38;5;243m  The official command line client for Cloud Foundry\r\n \u001b[0m\u001b[38;5;252m cfn-lint      \u001b[0m\u001b[38;5;243m  Checks CloudFormation templates for practices and behaviour that could potentially be improved\r\n \u001b[0m\u001b[38;5;252m cfssl         \u001b[0m\u001b[38;5;243m  CFSSL: Cloudflare's PKI and TLS toolkit\r\n \u001b[0m\u001b[38;5;252m cfssljson     \u001b[0m\u001b[38;5;243m  cfssljson: Takes the JSON output from Cloudflare's cfssl and multirootca programs and writes certificates, keys, CSRs, and bundles to disk.\r\n \u001b[0m\u001b[38;5;252m chamber       \u001b[0m\u001b[38;5;243m  CLI for managing secrets\r\n \u001b[0m\u001b[38;5;252m changie       \u001b[0m\u001b[38;5;243m  Automated changelog tool for preparing releases with lots of customization options\r\n \u001b[0m\u001b[38;5;252m cheat         \u001b[0m\u001b[38;5;243m  cheat allows you to create and view interactive cheatsheets on the command-line. It was designed to help remind *nix system administrators of options for commands that they use frequently, but not frequently enough to remember\r\n \u001b[0m\u001b[38;5;252m checkmake     \u001b[0m\u001b[38;5;243m  experimental linter/analyzer for Makefiles\r\n \u001b[0m\u001b[38;5;252m checkov       \u001b[0m\u001b[38;5;243m  Prevent cloud misconfigurations and find vulnerabilities during build-time in infrastructure as code, container images and open source packages with Checkov by Bridgecrew\r\n \u001b[0m\u001b[38;5;252m chezmoi       \u001b[0m\u001b[38;5;243m  Manage your dotfiles across multiple diverse machines, securely\r\n \u001b[0m\u001b[38;5;252m chezscheme    \u001b[0m\u001b[38;5;243m  Chez Scheme is both a programming language and an implementation of that language, with supporting tools and documentation\r\n \u001b[0m\u001b[38;5;252m chicken       \u001b[0m\u001b[38;5;243m  CHICKEN is a compiler for the Scheme programming language\r\n \u001b[0m\u001b[38;5;252m chisel        \u001b[0m\u001b[38;5;243m  A fast TCP/UDP tunnel over HTTP\r\n \u001b[0m\u001b[38;5;252m choose        \u001b[0m\u001b[38;5;243m  A human-friendly and fast alternative to cut (and sometimes awk)\r\n \u001b[0m\u001b[38;5;252m chromedriver  \u001b[0m\u001b[38;5;243m  ChromeDriver is a standalone server that implements the W3C WebDriver and WebDriver BiDi standards\r\n \u001b[0m\u001b[38;5;252m cidr-merger   \u001b[0m\u001b[38;5;243m  A simple command line tool to merge ip/ip cidr/ip range, supports IPv4/IPv6\r\n \u001b[0m\u001b[38;5;252m cidrchk       \u001b[0m\u001b[38;5;243m  CLI tool for CIDR range operations (check, generate)\r\n \u001b[0m\u001b[38;5;252m cilium-cli    \u001b[0m\u001b[38;5;243m  CLI to install, manage & troubleshoot Kubernetes clusters running Cilium\r\n\u001b[0m\u001b[38;2;2;191;135m/\u001b[0m\u001b[0m\u001b[30m\u001b[47m \u001b[0m\r\n\u001b[0m\u001b[0m\u001b[38;2;98;98;98mesc\u001b[0m\u001b[38;2;74;74;74m clear filter\u001b[0m\u001b[38;2;60;60;60m • \u001b[0m\u001b[38;2;98;98;98menter\u001b[0m\u001b[38;2;74;74;74m confirm\r\n\u001b[0m\u001b[?25l"]
