[126.96492, "o", "\u001b[12Dmise self-update \r\nfmt                                                                 (\u001b[33m\u001b[3mFormats mise.toml\u001b[m)\r\ngen                                         (\u001b[33m\u001b[3mGenerate files for various tools/services\u001b[m)\r\ngenerate                                    (\u001b[33m\u001b[3mGenerate files for various tools/services\u001b[m)\r\ni                                                              (\u001b[33m\u001b[3mInstall a tool version\u001b[m)\r\nimplode                                         (\u001b[33m\u001b[3mRemoves mise CLI and all related data\u001b[m)\r\ninstall                                                        (\u001b[33m\u001b[3mInstall a tool version\u001b[m)\r\ninstall-into                                (\u001b[33m\u001b[3mInstall a tool version to a specific path\u001b[m)\r\nlatest                                 (\u001b[33m\u001b[3mGets the latest available version for a plugin\u001b[m)\r\nlink                                                (\u001b[33m\u001b[3mSymlinks a tool version into mise\u001b[m)\r\nlist                                          (\u001b[33m\u001b[3mList installed and active tool versions\u001b[m)\r\nln                                                  (\u001b[33m\u001b[3mSymlinks a tool version into mise\u001b[m)\r\nlock                   (\u001b[33m\u001b[3mUpdate lockfile checksums and URLs for all specified platforms\u001b[m)\r\nls                                            (\u001b[33m\u001b[3mList installed and active tool versions\u001b[m)\r\nls-remote                                (\u001b[33m\u001b[3mList runtime versions available for install.\u001b[m)\r\nmcp                            (\u001b[33m\u001b[3m[experimental] Run Model Context Protocol (MCP) server\u001b[m)\r\noutdated                                                 (\u001b[33m\u001b[3mShows outdated tool versions\u001b[m)\r\np                                                                      (\u001b[33m\u001b[3mManage plugins\u001b[m)\r\nplugins                                                                (\u001b[33m\u001b[3mManage plugins\u001b[m)\r\nprep                             (\u001b[33m\u001b[3m[experimental] Ensure project dependencies are ready\u001b[m)\r\nprepare                          (\u001b[33m\u001b[3m[experimental] Ensure project dependencies are ready\u001b[m)\r\nprune                                                 (\u001b[33m\u001b[3mDelete unused versions of tools\u001b[m)\r\nr                                                                         (\u001b[33m\u001b[3mRun task(s)\u001b[m)\r\nregistry                                              (\u001b[33m\u001b[3mList available tools to install\u001b[m)\r\nremove                                 (\u001b[33m\u001b[3mRemoves installed tool versions from mise.toml\u001b[m)\r\nreshim           (\u001b[33m\u001b[3mCreates new shims based on bin paths from currently installed tools.\u001b[m)\r\nrm                                     (\u001b[33m\u001b[3mRemoves installed tool versions from mise.toml\u001b[m)\r\nrun                                                                       (\u001b[33m\u001b[3mRun task(s)\u001b[m)\r\nsearch                                               (\u001b[33m\u001b[3mSearch for tools in the registry\u001b[m)\r\n\u001b[2C\u001b[7mlf-update                                                      (\u001b[33m\u001b[3mUpdates mise itself.\u001b[m\u001b[7m)\u001b[m\r\n\u001b[6C\u001b[97m\u001b[46m7 to 45 of 72\u001b[m\r\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[63C"]
