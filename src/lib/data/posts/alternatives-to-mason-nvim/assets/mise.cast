[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Streaming replication for SQLite\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mv\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Log file navigator\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;5;252mc\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mc\u001b[0m\u001b[38;5;252mk\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  The LocalStack CLI packaged using pyinstaller\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;5;252mk\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;5;252mg\u001b[0m\u001b[38;5;252mc\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  LogCLI is a command-line tool for querying and exploring logs in Grafana Loki\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  An extremely fast directory and filename linter - Bring some structure to your project filesystem\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252md\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  The next gen ls command\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252mu\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Lua language\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252mu\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252mg\u001b[0m\u001b[38;5;252mu\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mg\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252mv\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;243m  A language server that offers Lua language support - programmed in Lua\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252mu\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mj\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  a Just-In-Time Compiler for Lua\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252mu\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mu\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  A fast, small, safe, gradually typed embeddable scripting language derived from Lua\r\n\u001b[0m\u001b[38;2;2;191;135m/\u001b[0ml\u001b[0m\u001b[30m\u001b[47m \u001b[0m\r\n\u001b[0m\u001b[0m\u001b[38;2;98;98;98mesc\u001b[0m\u001b[38;2;74;74;74m clear filter\u001b[0m\u001b[38;2;60;60;60m • \u001b[0m\u001b[38;2;98;98;98menter\u001b[0m\u001b[38;2;74;74;74m confirm\r\n\u001b[0m\u001b[?25l"]
