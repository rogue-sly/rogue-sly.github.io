[109.106695, "o", "\r\nactivate                                (\u001b[33m\u001b[3mInitializes mise in the current shell session\u001b[m)\r\nb                                                                     (\u001b[33m\u001b[3mManage backends\u001b[m)\r\nbackends                                                              (\u001b[33m\u001b[3mManage backends\u001b[m)\r\nbin-paths                                       (\u001b[33m\u001b[3mList all the active runtime bin paths\u001b[m)\r\ncache                                                           (\u001b[33m\u001b[3mManage the mise cache\u001b[m)\r\ncfg                                                               (\u001b[33m\u001b[3mManage config files\u001b[m)\r\ncompletion                                                 (\u001b[33m\u001b[3mGenerate shell completions\u001b[m)\r\nconfig                                                            (\u001b[33m\u001b[3mManage config files\u001b[m)\r\ndeactivate                                     (\u001b[33m\u001b[3mDisable mise for current shell session\u001b[m)\r\ndoctor                                  (\u001b[33m\u001b[3mCheck mise installation for possible problems\u001b[m)\r\ndr                                      (\u001b[33m\u001b[3mCheck mise installation for possible problems\u001b[m)\r\ne                                     (\u001b[33m\u001b[3mExports env vars to activate mise a single time\u001b[m)\r\nedit                                                     (\u001b[33m\u001b[3mEdit mise.toml interactively\u001b[m)\r\nen  (\u001b[33m\u001b[3mStarts a new shell with the mise environment built from the current configuration\u001b[m)\r\n\u001b[97m\u001b[46m…and 58 more rows\u001b[m\r\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[51C"]
[109.315313, "o", "\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\nenv                                   (\u001b[33m\u001b[3mExports env vars to activate mise a single time\u001b[m)\r\nexec                                               (\u001b[33m\u001b[3mExecute a command with tool(s) set\u001b[m)\r\nfmt                                                                 (\u001b[33m\u001b[3mFormats mise.toml\u001b[m)\r\ngen                                         (\u001b[33m\u001b[3mGenerate files for various tools/services\u001b[m)\r\ngenerate                                    (\u001b[33m\u001b[3mGenerate files for various tools/services\u001b[m)\r\ni                                                              (\u001b[33m\u001b[3mInstall a tool version\u001b[m)\r\nimplode                                         (\u001b[33m\u001b[3mRemoves mise CLI and all related data\u001b[m)\r\ninstall                                                        (\u001b[33m\u001b[3mInstall a tool version\u001b[m)\r\ninstall-into                                (\u001b[33m\u001b[3mInstall a tool version to a specific path\u001b[m)\r\nlatest                                 (\u001b[33m\u001b[3mGets the latest available version for a plugin\u001b[m)\r\nlink                                                (\u001b[33m\u001b[3mSymlinks a tool version into mise\u001b[m)\r\nlist                                          (\u001b[33m\u001b[3mList installed and active tool versions\u001b[m)\r\nln                                                  (\u001b[33m\u001b[3mSymlinks a tool version into mise\u001b[m)\r\nlock                   (\u001b[33m\u001b[3mUpdate lockfile checksums and URLs for all specified platforms\u001b[m)\r\nls                                            (\u001b[33m\u001b[3mList installed and active tool versions\u001b[m)\r\n\u001b[97m\u001b[46mrows 1 to 29 of 72\u001b[m\r\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[51C"]
[110.241043, "o", "\u001b[5Dmise activate \r\n\u001b[7mactivate                                (\u001b[33m\u001b[3mInitializes mise in the current shell session\u001b[m\u001b[7m)\u001b[m\r\u001b[A\u001b[60C"]
