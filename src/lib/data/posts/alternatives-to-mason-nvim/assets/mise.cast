[6.519657, "o", "\u001b[0m\u001b[1m\u001b[38;2;117;113;249mTools\r\n\u001b[0m\u001b[38;5;243mSelect a tool to install\r\n\u001b[0m\u001b[38;2;247;128;226m❯\u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mb\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Lab wraps Git or Hub, making it simple to clone, fork, and interact with repositories on GitLab\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  lane is a task automation helper\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mz\u001b[0m\u001b[38;5;252my\u001b[0m\u001b[38;5;252md\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;5;252mc\u001b[0m\u001b[38;5;252mk\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  The lazier way to manage everything docker\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mz\u001b[0m\u001b[38;5;252my\u001b[0m\u001b[38;5;252mg\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  simple terminal UI for git commands\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mz\u001b[0m\u001b[38;5;252my\u001b[0m\u001b[38;5;252mj\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;5;252mu\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  TUI for journalctl, file system logs, as well Docker and Podman containers for quick viewing and filtering with fuzzy find, regex support (like fzf and grep) and coloring the output, written in Go with the gocui library\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mz\u001b[0m\u001b[38;5;252my\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252mh\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  A terminal-based SSH manager inspired by lazydocker and k9s - Written in go\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mf\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252mh\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;5;252mk\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Fast and powerful Git hooks manager for any type of projects\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252mg\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  for automating Clojure projects without setting your hair on fire\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mv\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  An open source templating and deployment tool for HashiCorp Nomad jobs\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252mb\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252mq\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252mv\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  server mode of libSQL, which is a fork of SQLite that is both Open Source, and Open Contributions\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252mc\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;5;252mp\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  A license list generator of all your dependencies for iOS applications\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252mm\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Linux virtual machines, with a focus on running containers\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252mk\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252md\u001b[0m\u001b[3