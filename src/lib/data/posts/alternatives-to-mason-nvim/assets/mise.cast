[6.71932, "o", "\u001b[0m\u001b[1m\u001b[38;2;117;113;249mTools\r\n\u001b[0m\u001b[38;5;243mSelect a tool to install\r\n\u001b[0m\u001b[38;2;247;128;226m❯\u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Lua language\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252mg\u001b[0m\u001b[38;5;252mu\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mg\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252mv\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;243m  A language server that offers Lua language support - programmed in Lua\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mj\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  a Just-In-Time Compiler for Lua\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mu\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  A fast, small, safe, gradually typed embeddable scripting language derived from Lua\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252mq\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252mb\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Liquibase helps millions of developers track, version, and deploy database schema changes\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;2;2;191;135m l\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mz\u001b[0m\u001b[38;5;252my\u001b[0m\u001b[38;5;252mj\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  TUI for journalctl, file system logs, as well Docker and Podman containers for quick viewing and filtering with fuzzy find, regex support (like fzf and grep) and coloring the output, written in Go with the gocui library\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m a\u001b[0m\u001b[38;5;252mg\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;5;252mp\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252mg\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;5;252my\u001b[0m\u001b[38;5;252mu\u001b[0m\u001b[38;5;252mb\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252mk\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252my\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  age-plugin-yubikey is a plugin for age clients like age and rage, which enables files to be encrypted to age identities stored on YubiKeys\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m a\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Allure Report is a popular open source tool for visualizing the results of a test run\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m a\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mc\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  allurectl is the command line wrapper of Allure TestOps' API allowing you to upload the test results in real time from a build job, and managing entities on Allure TestOps side (test cases, launches, projects)\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m c\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mw\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252md\u001b[0m\u001b[38;5;252mm\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  clusterawsadm provides helpers for bootstrapping Kubernetes Cluster API Provider AWS\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m c\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252mc\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Home for Cluster API, a subproject of sig-cluster-lifecycle\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m f\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Flutter is an open source framework for building beautiful, natively compiled, multi-platform applications from a single codebase\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m f\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252mg\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  The Flutter code generator for your assets, fonts, colors, … — Get rid of all String-based APIs\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m f\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252mx\u001b[0m\u001b[38;5;252m2\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Open and extensible continuous delivery solution for Kubernetes. Powered by GitOps Toolkit\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m p\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  A cli tool to help discover deprecated apiVersions in Kubernetes\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m p\u001b[0m\u001b[38;5;252mu\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252mm\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Pulumi - Infrastructure as Code in any programming language\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m s\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252my\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  A Lua code formatter\r\n"]
[6.719374, "o", " \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m v\u001b[0m\u001b[38;5;252mc\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  vCluster - Create fully functional virtual Kubernetes clusters - Each vcluster runs inside a namespace of the underlying k8s cluster. It's cheaper than creating separate full-blown clusters and it offers better multi-tenancy and isolation than regular namespaces\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m r\u001b[0m\u001b[38;5;252mb\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mc\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;5;252mk\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252mp\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Easily find roles and cluster roles attached to any user, service account, or group name in your Kubernetes cluster\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m t\u001b[0m\u001b[38;5;252mf\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;5;252mk\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252mp\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Lookup resource attributes in tfstate\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m a\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252mg\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252mt\u001b[0m\u001b[38;5;252ms\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Progressive Delivery for Kubernetes\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m c\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252mm\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;5;252mc\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  CLI to install, manage & troubleshoot Kubernetes clusters running Cilium\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m c\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252mm\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;5;252mh\u001b[0m\u001b[38;5;252mu\u001b[0m\u001b[38;5;252mb\u001b[0m\u001b[38;5;252mb\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Hubble - Network, Service & Security Observability for Kubernetes using eBPF\r\n \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m c\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252md\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Claude Code is an agentic coding tool that lives in your terminal, understands your codebase, and helps you code faster by executing routine tasks, explaining complex code, and handling git workflows -- all through natural language commands\r\n"]
[6.719424, "o", " \u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m c\u001b[0m\u001b[38;2;2;191;135ml\u001b[0m\u001b[38;5;252ma\u001b[0m\u001b[38;2;2;191;135mu\u001b[0m\u001b[38;5;252md\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252m-\u001b[0m\u001b[38;5;252mp\u001b[0m\u001b[38;5;252mo\u001b[0m\u001b[38;5;252mw\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252mr\u001b[0m\u001b[38;5;252ml\u001b[0m\u001b[38;5;252mi\u001b[0m\u001b[38;5;252mn\u001b[0m\u001b[38;5;252me\u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;252m \u001b[0m\u001b[38;5;243m  Beautiful vim-style powerline statusline for Claude Code\r\n\u001b[0m\u001b[38;2;2;191;135m/\u001b[0mlu\u001b[0m\u001b[30m\u001b[47m \u001b[0m\r\n\u001b[0m\u001b[0m\u001b[38;2;98;98;98mesc\u001b[0m\u001b[38;2;74;74;74m clear filter\u001b[0m\u001b[38;2;60;60;60m • \u001b[0m\u001b[38;2;98;98;98menter\u001b[0m\u001b[38;2;74;74;74m confirm\r\n\u001b[0m\u001b[?25l"]
