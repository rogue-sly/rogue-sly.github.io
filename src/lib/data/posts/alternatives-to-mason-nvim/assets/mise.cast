[56.614677, "o", "\u001b[0m\u001b[1m\u001b[38;2;117;113;249mTools\r\n\u001b[0m\u001b[38;5;243mSelect a tool to install\r\n \u001b[0m\u001b[38;5;252m codefresh               \u001b[0m\u001b[38;5;243m  The Codefresh CLI provides a full and flexible interface to interact with Codefresh\r\n \u001b[0m\u001b[38;5;252m codeql                  \u001b[0m\u001b[38;5;243m  CodeQL CLI\r\n \u001b[0m\u001b[38;5;252m coder                   \u001b[0m\u001b[38;5;243m  Provision remote development environments via Terraform\r\n \u001b[0m\u001b[38;5;252m codex                   \u001b[0m\u001b[38;5;243m  Lightweight coding agent that runs in your terminal\r\n \u001b[0m\u001b[38;5;252m colima                  \u001b[0m\u001b[38;5;243m  Container runtimes on macOS (and Linux) with minimal setup\r\n \u001b[0m\u001b[38;5;252m committed               \u001b[0m\u001b[38;5;243m  Nitpicking commit history since beabf39\r\n \u001b[0m\u001b[38;5;252m conan                   \u001b[0m\u001b[38;5;243m  Decentralized, open-source (MIT), C/C++ package manager\r\n \u001b[0m\u001b[38;5;252m concourse               \u001b[0m\u001b[38;5;243m  Concourse is a container-based automation system written in Go\r\n \u001b[0m\u001b[38;5;252m conduit                 \u001b[0m\u001b[38;5;243m  Conduit streams data between data stores. Kafka Connect replacement. No JVM required\r\n \u001b[0m\u001b[38;5;252m conform                 \u001b[0m\u001b[38;5;243m  Policy enforcement for your pipelines\r\n\u001b[0m\u001b[38;2;247;128;226m❯\u001b[0m\u001b[38;5;252m conftest                \u001b[0m\u001b[38;5;243m  Write tests against structured configuration data using the Open Policy Agent Rego query language\r\n \u001b[0m\u001b[38;5;252m consul                  \u001b[0m\u001b[38;5;243m  Consul is a distributed, highly available, and data center aware solution to connect and configure applications across dynamic, distributed infrastructure\r\n \u001b[0m\u001b[38;5;252m container               \u001b[0m\u001b[38;5;243m  A tool for creating and running Linux containers using lightweight virtual machines on a Mac.\r\n \u001b[0m\u001b[38;5;252m container-structure-test\u001b[0m\u001b[38;5;243m  validate the structure of your container images\r\n \u001b[0m\u001b[38;5;252m container-use           \u001b[0m\u001b[38;5;243m  Development environments for coding agents. Enable multiple agents to work safely and independently with your preferred stack.\r\n \u001b[0m\u001b[38;5;252m cookiecutter            \u001b[0m\u001b[38;5;243m  Create projects swiftly from cookiecutters (project templates) with this command-line utility. Ideal for generating Python package projects and more\r\n \u001b[0m\u001b[38;5;252m copier                  \u001b[0m\u001b[38;5;243m  A library and CLI app for rendering project templates\r\n \u001b[0m\u001b[38;5;252m copper                  \u001b[0m\u001b[38;5;243m  A configuration file validator for Kubernetes\r\n \u001b[0m\u001b[38;5;252m coredns                 \u001b[0m\u001b[38;5;243m  CoreDNS: DNS and Service Discovery\r\n \u001b[0m\u001b[38;5;252m coreutils               \u001b[0m\u001b[38;5;243m  Cross-platform Rust rewrite of the GNU coreutils\r\n \u001b[0m\u001b[38;5;252m cosign                  \u001b[0m\u001b[38;5;243m  Code signing and transparency for containers and binaries\r\n \u001b[0m\u001b[38;5;252m coursier                \u001b[0m\u001b[38;5;243m  Pure Scala Artifact Fetching\r\n \u001b[0m\u001b[38;5;252m cowsay                  \u001b[0m\u001b[38;5;243m  cowsay is a configurable talking cow, originally written in Perl by Tony Monroe\r\n"]
