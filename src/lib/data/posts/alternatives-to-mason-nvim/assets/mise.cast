[131.276658, "o", "\u001b[7Dmise version \r\nregistry                                              (\u001b[33m\u001b[3mList available tools to install\u001b[m)\r\nremove                                 (\u001b[33m\u001b[3mRemoves installed tool versions from mise.toml\u001b[m)\r\nreshim           (\u001b[33m\u001b[3mCreates new shims based on bin paths from currently installed tools.\u001b[m)\r\nrm                                     (\u001b[33m\u001b[3mRemoves installed tool versions from mise.toml\u001b[m)\r\nrun                                                                       (\u001b[33m\u001b[3mRun task(s)\u001b[m)\r\nsearch                                               (\u001b[33m\u001b[3mSearch for tools in the registry\u001b[m)\r\nself-update                                                      (\u001b[33m\u001b[3mUpdates mise itself.\u001b[m)\r\nset                                            (\u001b[33m\u001b[3mSet environment variables in mise.toml\u001b[m)\r\nsettings                                                              (\u001b[33m\u001b[3mManage settings\u001b[m)\r\nsh                                       (\u001b[33m\u001b[3mSets a tool version for the current session.\u001b[m)\r\nshell                                    (\u001b[33m\u001b[3mSets a tool version for the current session.\u001b[m)\r\nshell-alias                                                     (\u001b[33m\u001b[3mManage shell aliases.\u001b[m)\r\nsync                          (\u001b[33m\u001b[3mSynchronize tools from other version managers with mise\u001b[m)\r\nt                                                                        (\u001b[33m\u001b[3mManage tasks\u001b[m)\r\ntasks                                                                    (\u001b[33m\u001b[3mManage tasks\u001b[m)\r\ntest-tool                                           (\u001b[33m\u001b[3mTest a tool installs and executes\u001b[m)\r\ntool                                                    (\u001b[33m\u001b[3mGets information about a tool\u001b[m)\r\ntool-alias                                               (\u001b[33m\u001b[3mManage tool version aliases.\u001b[m)\r\ntool-stub                                                         (\u001b[33m\u001b[3mExecute a tool stub\u001b[m)\r\ntrust                                                  (\u001b[33m\u001b[3mMarks a config file as trusted\u001b[m)\r\nu                                  (\u001b[33m\u001b[3mInstalls a tool and adds the version to mise.toml.\u001b[m)\r\nuninstall                                             (\u001b[33m\u001b[3mRemoves installed tool versions\u001b[m)\r\nunset                            (\u001b[33m\u001b[3mRemove environment variable(s) from the config file.\u001b[m)\r\nunuse                                  (\u001b[33m\u001b[3mRemoves installed tool versions from mise.toml\u001b[m)\r\nup                                                            (\u001b[33m\u001b[3mUpgrades outdated tools\u001b[m)\r\nupgrade                                                       (\u001b[33m\u001b[3mUpgrades outdated tools\u001b[m)\r\nuse                                (\u001b[33m\u001b[3mInstalls a tool and adds the version to mise.toml.\u001b[m)\r\nv                                                         (\u001b[33m\u001b[3mDisplay the version of mise\u001b[m)\r\n\u001b[C\u001b[7mersion                                                   (\u001b[33m\u001b[3mDisplay the version of mise\u001b[m\u001b[7m)\u001b[m\r\n\u001b[6C\u001b[97m\u001b[46m9 to 67 of 72\u001b[m\r\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[59C"]
