[53.278377, "o", "\u001b[0m\u001b[1m\u001b[38;2;117;113;249mTools\r\n\u001b[0m\u001b[38;5;243mSelect a tool to install\r\n \u001b[0m\u001b[38;5;252m bitwarden                \u001b[0m\u001b[38;5;243m  Bitwarden CLI\r\n \u001b[0m\u001b[38;5;252m bitwarden-secrets-manager\u001b[0m\u001b[38;5;243m  CLI for interacting with the Bitwarden Secrets Manager\r\n\u001b[0m\u001b[38;2;247;128;226m❯\u001b[0m\u001b[38;5;252m black                    \u001b[0m\u001b[38;5;243m  The uncompromising Python code formatter\r\n \u001b[0m\u001b[38;5;252m blender                  \u001b[0m\u001b[38;5;243m  Blender is a free and open-source 3D computer graphics software\r\n \u001b[0m\u001b[38;5;252m bob                      \u001b[0m\u001b[38;5;243m  A version manager for neovim\r\n \u001b[0m\u001b[38;5;252m boilerplate              \u001b[0m\u001b[38;5;243m  A tool for generating files and folders (\"boilerplate\") from a set of templates\r\n \u001b[0m\u001b[38;5;252m bombardier               \u001b[0m\u001b[38;5;243m  Fast cross-platform HTTP benchmarking tool written in Go\r\n \u001b[0m\u001b[38;5;252m borg                     \u001b[0m\u001b[38;5;243m  Deduplicating archiver with compression and authenticated encryption\r\n \u001b[0m\u001b[38;5;252m bosh                     \u001b[0m\u001b[38;5;243m  The bosh CLI is the command line tool used for interacting with all things BOSH, from deployment operations to software release management\r\n \u001b[0m\u001b[38;5;252m bottom                   \u001b[0m\u001b[38;5;243m  Yet another cross-platform graphical process/system monitor\r\n \u001b[0m\u001b[38;5;252m boundary                 \u001b[0m\u001b[38;5;243m  Boundary enables identity-based access management for dynamic infrastructure\r\n \u001b[0m\u001b[38;5;252m bpkg                     \u001b[0m\u001b[38;5;243m  Lightweight bash package manager\r\n \u001b[0m\u001b[38;5;252m brig                     \u001b[0m\u001b[38;5;243m  Brigade CLI. Event-driven scripting for Kubernetes\r\n \u001b[0m\u001b[38;5;252m btop                     \u001b[0m\u001b[38;5;243m  A monitor of resources\r\n \u001b[0m\u001b[38;5;252m btrace                   \u001b[0m\u001b[38;5;243m  BTrace - a safe, dynamic tracing tool for the Java platform\r\n \u001b[0m\u001b[38;5;252m buck2                    \u001b[0m\u001b[38;5;243m  A fast, hermetic, multi-language build system\r\n \u001b[0m\u001b[38;5;252m buf                      \u001b[0m\u001b[38;5;243m  The best way of working with Protocol Buffers\r\n \u001b[0m\u001b[38;5;252m buildifier               \u001b[0m\u001b[38;5;243m  buildifier: For formatting BUILD, BUILD.bazel and BUCK files in a standard way\r\n \u001b[0m\u001b[38;5;252m buildpack                \u001b[0m\u001b[38;5;243m  CLI for building apps using Cloud Native Buildpacks\r\n \u001b[0m\u001b[38;5;252m bun                      \u001b[0m\u001b[38;5;243m  Bun is a fast JavaScript all-in-one toolkit\r\n \u001b[0m\u001b[38;5;252m cabal                    \u001b[0m\u001b[38;5;243m  Cabal(haskell): Common Architecture for Building Applications and Libraries\r\n"]
[53.278389, "o", " \u001b[0m\u001b[38;5;252m caddy                    \u001b[0m\u001b[38;5;243m  Fast, multi-platform web server with automatic HTTPS\r\n \u001b[0m\u001b[38;5;252m calendarsync             \u001b[0m\u001b[38;5;243m  Stateless CLI tool to sync calendars across different calendaring systems\r\n \u001b[0m\u001b[38;5;252m calicoctl                \u001b[0m\u001b[38;5;243m  Cloud native networking and network security\r\n \u001b[0m\u001b[38;5;252m carapace                 \u001b[0m\u001b[38;5;243m  A multi-shell completion binary\r\n\u001b[0m\u001b[38;2;2;191;135m/\u001b[0m\u001b[0m\u001b[30m\u001b[47m \u001b[0m\r\n\u001b[0m\u001b[0m\u001b[38;2;98;98;98mesc\u001b[0m\u001b[38;2;74;74;74m clear filter\u001b[0m\u001b[38;2;60;60;60m • \u001b[0m\u001b[38;2;98;98;98menter\u001b[0m\u001b[38;2;74;74;74m confirm\r\n\u001b[0m"]
