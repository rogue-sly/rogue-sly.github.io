[51.349802, "o", "\u001b[0m\u001b[1m\u001b[38;2;117;113;249mTools\r\n\u001b[0m\u001b[38;5;243mSelect a tool to install\r\n \u001b[0m\u001b[38;5;252m apko                 \u001b[0m\u001b[38;5;243m  Build OCI images from APK packages directly without Dockerfile\r\n \u001b[0m\u001b[38;5;252m apollo-ios           \u001b[0m\u001b[38;5;243m  Apollo iOS Code Generation\r\n \u001b[0m\u001b[38;5;252m apollo-router        \u001b[0m\u001b[38;5;243m  A configurable, high-performance routing runtime for Apollo Federation\r\n \u001b[0m\u001b[38;5;252m apollo-rover         \u001b[0m\u001b[38;5;243m  The CLI for Apollo GraphOS\r\n\u001b[0m\u001b[38;2;247;128;226m❯\u001b[0m\u001b[38;5;252m aqua                 \u001b[0m\u001b[38;5;243m  Declarative CLI Version manager written in Go. Support Lazy Install, Registry, and continuous update with Renovate. CLI version is switched seamlessly\r\n \u001b[0m\u001b[38;5;252m arduino              \u001b[0m\u001b[38;5;243m  Arduino command line tool\r\n \u001b[0m\u001b[38;5;252m argc                 \u001b[0m\u001b[38;5;243m  A Bash CLI framework, also a Bash command runner\r\n \u001b[0m\u001b[38;5;252m argo                 \u001b[0m\u001b[38;5;243m  Argo Workflows CLI. Workflow engine for Kubernetes\r\n \u001b[0m\u001b[38;5;252m argo-rollouts        \u001b[0m\u001b[38;5;243m  Progressive Delivery for Kubernetes\r\n \u001b[0m\u001b[38;5;252m argocd               \u001b[0m\u001b[38;5;243m  Declarative continuous deployment for Kubernetes\r\n \u001b[0m\u001b[38;5;252m asciidoctorj         \u001b[0m\u001b[38;5;243m  AsciidoctorJ is the official library for running Asciidoctor on the JVM. Using AsciidoctorJ, you can convert AsciiDoc content or analyze the structure of a parsed AsciiDoc document from Java and other JVM languages\r\n \u001b[0m\u001b[38;5;252m assh                 \u001b[0m\u001b[38;5;243m  make your ssh client smarter\r\n \u001b[0m\u001b[38;5;252m ast-grep             \u001b[0m\u001b[38;5;243m  A CLI tool for code structural search, lint and rewriting. Written in Rust\r\n \u001b[0m\u001b[38;5;252m astro                \u001b[0m\u001b[38;5;243m  CLI that makes it easy to create, test and deploy Airflow DAGs to Astronomer\r\n \u001b[0m\u001b[38;5;252m atlas                \u001b[0m\u001b[38;5;243m  A modern tool for managing database schemas\r\n \u001b[0m\u001b[38;5;252m atlas-community      \u001b[0m\u001b[38;5;243m  A modern tool for managing database schemas (Community Edition)\r\n \u001b[0m\u001b[38;5;252m atmos                \u001b[0m\u001b[38;5;243m  Workflow automation tool for DevOps. Keep configuration DRY with hierarchical imports of configurations, inheritance, and WAY more. Native support for Terraform and Helmfile\r\n \u001b[0m\u001b[38;5;252m atuin                \u001b[0m\u001b[38;5;243m  ✨ Magical shell history\r\n \u001b[0m\u001b[38;5;252m auto-doc             \u001b[0m\u001b[38;5;243m  Github action that turns your reusable workflows and custom actions into easy to read markdown tables\r\n \u001b[0m\u001b[38;5;252m aws-cli              \u001b[0m\u001b[38;5;243m  The AWS Command Line Interface (AWS CLI v2) is a unified tool that provides a consistent interface for interacting with all parts of Amazon Web Services\r\n \u001b[0m\u001b[38;5;252m aws-copilot          \u001b[0m\u001b[38;5;243m  The AWS Copilot CLI is a tool for developers to build, release and operate production ready containerized applications on AWS App Runner, Amazon ECS, and AWS Fargate\r\n \u001b[0m\u001b[38;5;252m aws-iam-authenticator\u001b[0m\u001b[38;5;243m  A tool to use AWS IAM credentials to authenticate to a Kubernetes cluster\r\n \u001b[0m\u001b[38;5;252m aws-nuke             \u001b[0m\u001b[38;5;243m  Remove all the resources from an AWS account\r\n \u001b[0m\u001b[38;5;252m aws-sam              \u001b[0m\u001b[38;5;243m  CLI tool to build, test, debug, and deploy Serverless applications using AWS SAM\r\n \u001b[0m\u001b[38;5;252m aws-sso              \u001b[0m\u001b[38;5;243m  A powerful tool for using AWS Identity Center for the CLI and web console\r\n\u001b[0m\u001b[38;2;2;191;135m/\u001b[0m\u001b[0m\u001b[30m\u001b[47m \u001b[0m\r\n\u001b[0m\u001b[0m\u001b[38;2;98;98;98mesc\u001b[0m\u001b[38;2;74;74;74m clear filter\u001b[0m\u001b[38;2;60;60;60m • \u001b[0m\u001b[38;2;98;98;98menter\u001b[0m\u001b[38;2;74;74;74m confirm\r\n\u001b[0m\u001b[?25l"]
