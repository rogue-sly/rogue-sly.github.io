{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "den",
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "test:unit": "vitest",
        "lint": "eslint . && prettier --check .",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@sveltejs/adapter-static": "^3.0.10",
        "@sveltejs/kit": "^2.50.2",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@types/eslint": "^9.6.1",
        "@types/jsdom": "^27.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.14.0",
        "globals": "^17.3.0",
        "jsdom": "^28.0.0",
        "mdsvex": "^0.12.6",
        "prettier-plugin-svelte": "^3.4.1",
        "rehype-stringify": "^10.0.1",
        "remark": "^15.0.1",
        "remark-gfm": "^4.0.1",
        "remark-parse": "^11.0.0",
        "remark-rehype": "^11.1.2",
        "shiki": "^3.22.0",
        "svelte": "^5.50.0",
        "svelte-check": "^4.3.6",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.54.0",
        "unified": "^11.0.5",
        "vite": "^7.3.1",
        "vitest": "^4.0.18",
        "xmlbuilder2": "^4.0.3"
    },
    "dependencies": {
        "asciinema-player": "3.14.0",
        "cookie": "^1.1.1",
        "esbuild": "^0.27.3"
    },
    "exports": {
        "./package.json": "./package.json",
        "./assets/images/gideon-animated.webp": "./package/assets/images/gideon-animated.webp",
        "./assets/images/gideon.webp": "./package/assets/images/gideon.webp",
        "./assets/images/nothing.png": "./package/assets/images/nothing.png",
        "./components/BlogPost.svelte": {
            "types": "./package/components/BlogPost.svelte.d.ts",
            "svelte": "./package/components/BlogPost.svelte",
            "default": "./package/components/BlogPost.svelte"
        },
        "./layout/Footer.svelte": {
            "types": "./package/layout/Footer.svelte.d.ts",
            "svelte": "./package/layout/Footer.svelte",
            "default": "./package/layout/Footer.svelte"
        },
        "./layout/Header.svelte": {
            "types": "./package/layout/Header.svelte.d.ts",
            "svelte": "./package/layout/Header.svelte",
            "default": "./package/layout/Header.svelte"
        },
        "./site-config": {
            "types": "./package/site-config.d.ts",
            "default": "./package/site-config.js"
        },
        "./style/abstracts/colorscheme.css": "./package/style/abstracts/colorscheme.css",
        "./style/abstracts/font.css": "./package/style/abstracts/font.css",
        "./style/abstracts/global.css": "./package/style/abstracts/global.css",
        "./style/abstracts/util.css": "./package/style/abstracts/util.css",
        "./style/abstracts/variables.css": "./package/style/abstracts/variables.css",
        "./types": {
            "types": "./package/types.d.ts",
            "default": "./package/types.js"
        },
        "./utils": {
            "types": "./package/utils.d.ts",
            "default": "./package/utils.js"
        }
    },
    "files": [
        "package"
    ],
    "typesVersions": {
        ">4.0": {
            "components/BlogPost.svelte": [
                "./package/components/BlogPost.svelte.d.ts"
            ],
            "layout/Footer.svelte": [
                "./package/layout/Footer.svelte.d.ts"
            ],
            "layout/Header.svelte": [
                "./package/layout/Header.svelte.d.ts"
            ],
            "site-config": [
                "./package/site-config.d.ts"
            ],
            "types": [
                "./package/types.d.ts"
            ],
            "utils": [
                "./package/utils.d.ts"
            ]
        }
    }
}
